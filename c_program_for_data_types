#include <stdio.h>

int main() {
    int age = 20;
    float height = 5.8f;
    char grade = 'A';
    double salary = 55000.75;

    printf("Integer (age)   : %d\n", age);
    printf("Float (height)  : %.2f\n", height);
    printf("Character (grade): %c\n", grade);
    printf("Double (salary) : %.2lf\n", salary);

    return 0;
}
Output
Integer (age)   : 20
Float (height)  : 5.80
Character (grade): A
Double (salary) : 55000.75
