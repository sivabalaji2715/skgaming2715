include <stdio.h>

int main() {
    // Variable declaration (Keywords: int, float)
    int a = 10, b = 5;
    float result;

    // Constant
    const float PI = 3.14;

    // Arithmetic Operators
    result = a + b;

    // Display the values
    printf("Value of a = %d\n", a);
    printf("Value of b = %d\n", b);
    printf("Addition = %.2f\n", result);

    // Relational Operator
    if (a > b) {
        printf("a is greater than b\n");
    }

    // Logical Operator
    if (a > 0 && b > 0) {
        printf("Both numbers are positive.\n");
    }

    // Display constant
    printf("Value of PI = %.2f\n", PI);

    return 0;
}
